# =============================================================================
# Backend — copy to backend/.env
# =============================================================================

# Database
DATABASE_URL=postgresql://app:app@localhost:5432/app
PGBOUNCER_MODE=false

# JWT — generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS — comma-separated list of allowed frontend origins
FRONTEND_URL=http://localhost:3000

# Internal API secret — shared between Next.js server and FastAPI
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=your-internal-secret-here

# OAuth — Google (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email — Resend (optional — emails disabled when absent)
RESEND_API_KEY=
MAIL_FROM=noreply@yourdomain.com
MAIL_FROM_NAME=My App

# Cloudinary — image uploads (optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Sentry — backend error tracking (optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# Slack Bot — alert notifications (optional)
# Bot Token from api.slack.com → Your App → OAuth & Permissions (xoxb-...)
SLACK_BOT_TOKEN=

# Trusted proxy IPs for ProxyHeadersMiddleware
# Use "*" on Railway (traffic passes through Railway's proxy)
TRUSTED_PROXY_IPS=127.0.0.1


# =============================================================================
# Frontend — copy to frontend/.env.local
# =============================================================================

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-here

# FastAPI URL (server-side Next.js calls)
API_URL=http://localhost:8000
# FastAPI URL (client-side browser calls)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Internal API secret (same as backend)
INTERNAL_API_SECRET=your-internal-secret-here

# OAuth — Google (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Sentry — frontend error tracking (optional)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
