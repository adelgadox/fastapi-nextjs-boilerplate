# =============================================================================
# Backend — copy to backend/.env
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://app:app@localhost:5432/app
PGBOUNCER_MODE=false

# ── JWT — generate with: openssl rand -hex 32 ─────────────────────────────────
SECRET_KEY=your-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── CORS — comma-separated list of allowed frontend origins ───────────────────
FRONTEND_URL=http://localhost:3000

# ── Internal API secret — generate with: openssl rand -hex 32 ────────────────
# Shared between Next.js server and FastAPI to protect /internal/* routes
INTERNAL_API_SECRET=your-internal-secret-here

# ── Email — Resend ────────────────────────────────────────────────────────────
RESEND_API_KEY=
MAIL_FROM=noreply@yourdomain.com
MAIL_FROM_NAME=My App

# ── Trusted proxy IPs ─────────────────────────────────────────────────────────
# Use "*" on Railway (traffic passes through Railway's proxy)
TRUSTED_PROXY_IPS=127.0.0.1

# ── Sentry — backend error tracking (optional) ────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# ── Slack Bot — alert notifications (optional) ────────────────────────────────
# Create app at api.slack.com → OAuth & Permissions → Bot Token (xoxb-...)
SLACK_BOT_TOKEN=

# ── OAuth — Google (optional) ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =============================================================================
# OPTIONAL LAYERS — see docs/optional-layers.md for full setup
# =============================================================================

# ── Cloudinary — image / video uploads ───────────────────────────────────────
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ── AI / OpenAI-compatible provider ──────────────────────────────────────────
# Works with OpenAI, DeepSeek, Groq, Together AI, etc.
# AI_API_KEY=
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini

# ── Langfuse — LLM observability ─────────────────────────────────────────────
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com

# ── Stripe — payments & subscriptions ────────────────────────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID_PRO=

# ── Redis — caching / queues ──────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379/0

# ── 2FA / TOTP — authenticator app codes ─────────────────────────────────────
# TOTP_ISSUER=My App

# ── GeoIP / MaxMind — country / city lookup ──────────────────────────────────
# Download GeoLite2-City.mmdb at maxmind.com (free account required)
# GEOIP_DB_PATH=/data/GeoLite2-City.mmdb

# ── ElevenLabs + Cloudflare R2 — AI voice generation ─────────────────────────
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=https://pub-xxx.r2.dev


# =============================================================================
# Frontend — copy to frontend/.env.local
# =============================================================================

NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here

# FastAPI URL (server-side Next.js calls)
API_URL=http://localhost:8000
# FastAPI URL (client-side browser calls)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Internal API secret (same value as backend)
INTERNAL_API_SECRET=your-internal-secret-here

# ── OAuth — Google (optional) ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Sentry — frontend error tracking (optional) ───────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
